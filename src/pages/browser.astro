---
import Layout from "../layouts/Layout.astro";
import ContentBody from "../components/ContentBody.astro";
import { getEntry, render } from "astro:content";
import releasesData from "../data/releases.json";

const entry = await getEntry("content", "browser");
if (!entry) throw new Error("Missing content/browser.md");
const { Content } = await render(entry);

type Release = { tag: string; url: string; date: string };
type RepoData = { downloadUrl: string; releases: Release[] };

const repo = "General-Sentiment/Browser";
const { downloadUrl, releases: rawReleases } = (releasesData as Record<
  string,
  RepoData
>)[repo];
const releases = rawReleases.map((r) => ({
  tag: r.tag,
  url: r.url,
  date: r.date
    ? new Date(r.date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })
    : "",
}));
---

<Layout title={entry.data.title}>
  <main>
    <ContentBody updated={entry.data.updated} title={entry.data.title}>
      <p class="download"><a class="download-btn" href={downloadUrl}>Download for Mac</a></p>
      <Content />
      {
        releases.length > 0 && (
          <div class="releases">
            <table>
              <tbody>
                {releases.map((r) => (
                  <tr>
                    <td>
                      <a href={r.url}>{r.tag}</a>
                    </td>
                    <td>{r.date}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <p>
              <a href={`https://github.com/${repo}/releases`}>
                All releases on GitHub
              </a>
            </p>
          </div>
        )
      }
    </ContentBody>
  </main>
</Layout>

<style is:global>
  main {
    padding: 8rem 2rem;
  }

  @media (max-width: 768px) {
    main {
      padding: 6rem 1rem 1rem;
    }
  }

  .releases table {
    width: 100%;
    border-collapse: collapse;
  }

  .releases td {
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    vertical-align: baseline;
  }

  .releases td + td {
    text-align: right;
    color: var(--color-text-secondary);
  }

  .releases > p {
    margin-top: 1rem;
  }

  .content a.download-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    text-decoration: none;
    transition: background 250ms ease;
  }

  .content a.download-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }
</style>
