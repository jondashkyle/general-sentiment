---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("content");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const updated = entry.data.updated ? new Date(entry.data.updated).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) : null;
---

<Layout title={entry.data.title}>
  <main>
    <div class="content">
      <Content />
    </div>
    {updated && <footer class="page-footer">Last updated {updated}</footer>}
  </main>
</Layout>

<style is:global>
  main {
    padding: 8rem 2rem;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.5;
    margin: 0 auto;
    color: var(--color-text);
  }

  .content > * {
    max-width: 32rem;
    width: 100%;
  }

  .content > * + * {
    margin-top: 1.5rem;
  }

  .content > .figure-sm {
    max-width: 24rem;
  }
  .content > .figure-md {
    max-width: 32rem;
  }
  .content > .figure-lg {
    max-width: 48rem;
  }

  figure > div {
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }

  .content a {
    text-decoration: underline;
    text-decoration-color: var(--color-text-secondary);
    text-underline-offset: 0.25em;
  }

  .content h2 {
    font-size: inherit;
    font-weight: 600;
  }

  .content ul {
    list-style: disc;
    padding-left: 1.5rem;
  }

  .content ol {
    list-style: decimal;
    padding-left: 1.5rem;
  }

  .content ul li + li,
  .content ol li + li {
    margin-top: 0.5rem;
  }

  .content ul li::marker,
  .content ol li::marker {
    color: var(--color-text-secondary);
  }

  figcaption {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
  }

  .page-footer {
    margin-top: 4rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    main {
      padding: 6rem 1rem 1rem;
    }
  }
</style>
