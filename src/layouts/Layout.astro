---
interface Props {
  title?: string;
}

const { title = "sentiment" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>General {title}</title>
    <meta name="description" content="generally, sentimentally." />
    <meta property="og:title" content={`general ${title}`} />
    <meta property="og:description" content="generally, sentimentally." />
    <meta
      property="og:image"
      content="https://generalsentiment.co/social.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="antialiased loading">
    <slot />
    <script>
      document.fonts.ready.then(() => {
        document.body.classList.remove("loading");
      });
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  img,
  picture,
  video,
  svg {
    display: block;
    max-width: 100%;
  }

  input,
  button,
  textarea,
  select {
    font: inherit;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul,
  ol {
    list-style: none;
  }

  @font-face {
    font-family: "Uncut Sans";
    src: url("/fonts/UncutSans-Variable.ttf") format("truetype");
    font-weight: 100 900;
    font-display: block;
  }

  :root {
    --color-bg: #212121;
    --color-text: #ccc;
    --color-text-secondary: #666;
  }

  html {
    margin: 0;
    width: 100%;
    height: 100%;
    background: var(--color-bg);
  }

  body {
    margin: 0;
    width: 100%;
    height: 100%;
    color: var(--color-text);
    font-family: "Uncut Sans", sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.loading {
    visibility: hidden;
  }
</style>
